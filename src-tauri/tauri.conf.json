{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Skills Manager",
  "version": "0.2.3",
  "identifier": "com.alex.openskillsmanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open Skills Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Visual manager for AI IDE Skills",
    "longDescription": "A macOS native application for managing Skills across multiple AI IDEs with a modern glassmorphism UI",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQkI3Nzk4NDJEMDI3NTcKUldSWEo5QkNtSGU3WDFOR3dJdlVCVWoyV2JoeHZuWjZhMEl6NGVYNGsxRmZHRDZ6bDRKYi9MME8K",
      "endpoints": [
        "https://github.com/ImaginerLabs/Open-Skills-Manager/releases/latest/download/latest.json"
      ]
    }
  }
}
